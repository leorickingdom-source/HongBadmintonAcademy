# Shared secret the website uses to authenticate to this worker.
# MUST equal WA_WORKER_SECRET set in the Next.js app (Vercel env vars).
# Use a long random string, e.g. `openssl rand -hex 32`.
WA_WORKER_SECRET=change-me-to-a-long-random-string

# Port this worker listens on.
PORT=8787

# Canonical URL of the Next.js app. Set this to ENABLE the throttled
# auto-reminder drip (the worker polls the app for queued reminders). Leave
# unset to disable it — the manual POST /send still works either way.
APP_URL=https://hong-badminton-academy.vercel.app

# Only on ARM / Raspberry Pi, where the bundled Chromium can't run:
# install system chromium and point at it.
# CHROME_PATH=/usr/bin/chromium-browser
