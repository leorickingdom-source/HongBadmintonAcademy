# ─── Supabase ──────────────────────────────────────────────────────────────
# Project URL + anon (publishable) key — safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Service role key — SERVER ONLY. Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Stripe (payment gateway) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
PAYMENT_CURRENCY=MYR

# ─── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────
# Leave WHATSAPP_API_TOKEN empty in dev → messages are logged but NOT sent.
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=hba-verify-token
WHATSAPP_API_VERSION=v21.0

# Parent WhatsApp group invite link (https://chat.whatsapp.com/…). When set,
# enables the parent-dashboard join card, the /community-poster QR, and the
# super-admin "push invite to all parents" button. Get it from the group:
# Group info → Invite via link → Copy.
WA_COMMUNITY_LINK=

# ─── NFC tap ingest ────────────────────────────────────────────────────────
# Shared secret the NFC reader/bridge sends in the x-api-key header.
NFC_API_KEY=change-me-nfc-key

# ─── Cron (Vercel Cron / external scheduler) ───────────────────────────────
CRON_SECRET=change-me-cron-secret

# ─── Coach check-in geofence (optional, GLOBAL FALLBACK) ───────────────────
# Preferred: set each branch's location from Admin → Branches → Edit → "Use my
# current location" (per-branch, no env/redeploy needed). These env vars are only
# the fallback for branches that haven't configured their own. Leave blank to
# disable globally (the time-window guard still applies regardless).
ACADEMY_LAT=
ACADEMY_LNG=
# Allowed distance from the venue, in metres (default 300).
GEOFENCE_RADIUS_M=300
# true = block check-in when the browser won't share a location; false = allow
# but record it without geo proof.
GEOFENCE_REQUIRED=false
